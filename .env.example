# Nexa Environment Configuration Template
# Copy this file to .env and fill in your values for your own stack.
# DO NOT COMMIT YOUR .env FILE.

# --- Core API Keys ---
# Get your key at https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Get your key at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# For SDR Agent email sending (https://resend.com)
RESEND_API_KEY=your_resend_api_key_here

# --- Cerberus Configuration ---
CERBERUS_AGENT=career_twin
CERBERUS_CONFIG=/root/core/cerberus/configs/career-twin-agent.json
CERBERUS_API_URL=http://localhost:3000
CERBERUS_API_KEY=your_internal_cerberus_key

# --- Supabase / Database ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Infrastructure / Runtime ---
NEXA_ROOT=/path/to/nexa
NEXA_VAULT_FILE=/path/to/nexa/core/vault/nexa-vault.json
NEXA_DATA_DIR=/path/to/nexa/data
NEXA_LOG_DIR=/path/to/nexa/.nexa/logs
NEXA_PUBLIC_BASE_URL=https://your-domain.example
VPS_PASSWORD=
VPS_IP=
VPS_DOMAIN=
VPS_SSH_HOST=
VPS_SSH_USER=root
PEGASUS_ADMIN_PASSWORD=
NEXA_EXPORT_TOKEN=

# --- Sovereign Transport ---
NEXA_ROUTE_CLOUD_THROUGH_TOR=0
NEXA_TOR_SOCKS_URL=socks5://127.0.0.1:9050
NEXA_TOR_CONTROL_HOST=127.0.0.1
NEXA_TOR_CONTROL_PORT=9051
NEXA_TOR_CONTROL_PASSWORD=
NEXA_IPFS_API_URL=http://127.0.0.1:5001
NEXA_IPFS_GATEWAY_URL=http://127.0.0.1:8080

# --- WebAuthn / Passkey ---
WEBAUTHN_RP_ID=pegasus.meziani.org
WEBAUTHN_RP_NAME=Pegasus
WEBAUTHN_ORIGIN=https://pegasus.meziani.org
