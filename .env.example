# Dragun.app Environment Variables
# Copy to .env.local and fill in real values
# NEVER commit .env.local to version control

# App
NEXT_PUBLIC_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# AI Providers (at least one required)
# Google AI — recommended. Free tier covers pilot usage. Powers chat + embeddings.
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSyB...

# OpenRouter — optional fallback or override. Supports DeepSeek, Llama, Mistral, etc.
OPENROUTER_API_KEY=sk-or-v1-...

# Override the default model (optional). If unset, uses OpenRouter free router (openrouter/free).
# Examples:
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_MODEL=mistralai/mistral-small-3.1-24b-instruct:free

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Subscription Price IDs (create in Stripe Dashboard > Products)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...

# Monitoring (required in production)
SENTRY_DSN=https://...@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=

# Security (required in production)
ARCJET_KEY=aj_...

# Debtor portal token signing (optional; falls back to SUPABASE_SERVICE_ROLE_KEY)
# Use a dedicated secret in production for stronger isolation
DEBTOR_PORTAL_SECRET=

# Cron auth (Vercel sets this automatically for cron jobs; set manually for testing)
CRON_SECRET=

# Contact form: where to receive website contact submissions (optional; falls back to RESEND_FROM)
# CONTACT_EMAIL=hello@yourdomain.com

# Comms — at least one channel recommended for outreach (see docs/COMMS.md)
# Email (Resend): verify domain in Resend dashboard, then set:
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_...
# RESEND_FROM=Account Resolution <resolution@yourdomain.com>
# RESEND_WEBHOOK_SECRET=whsec_...  # Optional: bounce/complaint webhooks

# SMS (Twilio): optional until you have a Twilio number. When set, use SMS_PROVIDER=twilio and TWILIO_* below.
# If unset, SMS is noop (no delivery). Default SMS provider when configured is twilio.
# SMS_PROVIDER=noop
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM=+1234567890
# Optional: status callback for delivery/failure (defaults to NEXT_PUBLIC_URL + /api/webhooks/twilio/status)
# TWILIO_STATUS_CALLBACK_URL=https://your-domain.com/api/webhooks/twilio/status

# Comms test route (optional): set to allow POST /api/comms/test for manual email/SMS tests. Do not expose to client.
# COMMS_TEST_TOKEN=your-secret-token

# Outreach etiquette (empathy / minimum respect for debtors). Controls spacing and frequency across all companies.
# 0|minimal = no extra rules (only existing rate limits). 1|moderate = 24h spacing, 5/week, 7am–9pm UTC. 2|strict = 48h, 3/week, 8am–8pm UTC, no SMS weekend. 3|maximum = 72h, 2/week, 9am–7pm UTC, no SMS weekend.
# OUTREACH_ETIQUETTE_LEVEL=0
