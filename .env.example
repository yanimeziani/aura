# Aura Environment Configuration Template
# Copy this file to .env and fill in your values.
# DO NOT COMMIT YOUR .env FILE.

# --- Core API Keys ---
# Get your key at https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# For SDR Agent email sending (https://resend.com)
RESEND_API_KEY=your_resend_api_key_here

# --- Cerberus Configuration ---
CERBERUS_AGENT=career_twin
CERBERUS_CONFIG=/root/core/cerberus/configs/career-twin-agent.json
CERBERUS_API_URL=http://localhost:3000
CERBERUS_API_KEY=your_internal_cerberus_key

# --- Supabase / Database ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Infrastructure ---
VPS_SSH_HOST=89.116.170.202
VPS_SSH_USER=root
# PEGASUS_ADMIN_PASSWORD=change_this_immediately
