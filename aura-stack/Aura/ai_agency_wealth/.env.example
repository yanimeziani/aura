# To use standard OpenAI, uncomment and set this:
# OPENAI_API_KEY="sk-..."

# To use Ollama locally (100% Free & Open Source), uncomment these:
# OPENAI_API_BASE="http://localhost:11434/v1"
# OPENAI_API_KEY="ollama"
# OPENAI_MODEL_NAME="llama3"

# To use Groq (Fast & Free API for open source models), uncomment these:
# OPENAI_API_BASE="https://api.groq.com/openai/v1"
# OPENAI_API_KEY="gsk-..."
# OPENAI_MODEL_NAME="llama3-70b-8192"