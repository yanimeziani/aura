{
  # Global options
}

# Operations Center (meziani.org)
meziani.org, www.meziani.org {
  # CORS Configuration for the entire ecosystem
  header {
    Access-Control-Allow-Origin "https://meziani.ai"
    Access-Control-Allow-Methods "GET, POST, OPTIONS"
    Access-Control-Allow-Headers "Content-Type, Authorization"
    Access-Control-Allow-Credentials "true"
    # Existing security headers
    Strict-Transport-Security "max-age=31536000;"
  }

  # Handle CORS preflight (OPTIONS)
  @cors_preflight method OPTIONS
  handle @cors_preflight {
    respond "" 204
  }

  handle_path /api/* {
    reverse_proxy host.docker.internal:8000
  }
  handle_path /ops/* {
    reverse_proxy host.docker.internal:9100
  }
  handle_path /automation/* {
    reverse_proxy n8n:5678
  }
  handle {
    root * /srv/frontend
    file_server
    try_files {path} {path}/ /index.html
  }
}

