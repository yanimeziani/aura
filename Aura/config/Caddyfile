# Core Server Configuration for meziani.org and meziani.ai
# Optimized for automatic HTTPS (Let's Encrypt) 

meziani.org, www.meziani.org, meziani.ai, www.meziani.ai {
    root * /var/www/html/ai_agency_web
    file_server
    try_files {path} {path}/ /index.html

    # Backend SaaS API
    handle_path /api/* {
        reverse_proxy 127.0.0.1:8000
    }

    # n8n Automation Backend
    handle_path /automation/* {
        reverse_proxy 127.0.0.1:5678 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Custom styling for mobile/tablet (Z Fold 5)
    header {
        # Enable compression for faster mobile loading
        Access-Control-Allow-Origin *
        Strict-Transport-Security "max-age=31536000;"
    }
}

# Stripe should POST directly to a webhook endpoint (no redirects).
# Dedicated host avoids mixing webhook traffic with frontend routing.
pay.meziani.org {
    encode zstd gzip

    # Webhooks
    handle_path /webhook* {
        request_body {
            max_size 10MB
        }
        reverse_proxy 127.0.0.1:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Optional: everything else goes to API (safe default)
    handle {
        reverse_proxy 127.0.0.1:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }
}
