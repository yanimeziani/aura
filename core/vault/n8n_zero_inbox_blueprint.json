{
  "nodes": [
    {
      "parameters": {
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        },
        "filters": {
          "q": "is:unread -label:aura-processed"
        }
      },
      "name": "Gmail Trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1,
      "position": [400, 300]
    },
    {
      "parameters": {
        "model": "gpt-4o",
        "prompt": "Analyze this email based on the user's goals: {{ $node[\"Gmail Trigger\"].json[\"snippet\"] }}\n\nGoals: {{ $node[\"Load Goals\"].json }}\n\nCategorize as: HIGH_SIGNAL, ADMINISTRATIVE, or NOISE. Provide a 1-sentence summary.",
        "options": {}
      },
      "name": "Aura AI Categorizer",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [600, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $node[\"Aura AI Categorizer\"].json[\"category\"] }}",
              "value2": "HIGH_SIGNAL"
            }
          ]
        }
      },
      "name": "Signal Filter",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [800, 300]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "archive",
        "messageId": "={{ $node[\"Gmail Trigger\"].json[\"id\"] }}"
      },
      "name": "Auto-Archive Noise",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [1000, 450]
    }
  ],
  "connections": {
    "Gmail Trigger": {
      "main": [
        [
          {
            "node": "Aura AI Categorizer",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
