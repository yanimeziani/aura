{
  "default_temperature": 0.7,

  "models": {
    "providers": {
      "openrouter": {
        "api_key": "YOUR_OPENROUTER_API_KEY"
      }
    }
  },

  "agents": {
    "media": {
      "name": "Media Outreach Agent",
      "model": {
        "primary": "openrouter/anthropic/claude-sonnet-4",
        "fallback": "openrouter/meta-llama/llama-3.3-70b-instruct"
      },
      "system_prompt_file": "prompts/media_agent_prompt.txt",
      "max_tool_iterations": 20,
      "max_history": 50,
      "temperature": 0.7,
      "tools": [
        "web_fetch",
        "web_research",
        "email_draft",
        "email_send",
        "calendar_link"
      ],
      "memory": {
        "profile": "media_outreach",
        "auto_save": true,
        "context_window": 4000
      },
      "autonomy": {
        "level": "supervised",
        "workspace_only": true,
        "max_actions_per_hour": 10
      }
    }
  },

  "channels": {
    "cli": true,
    "web": {
      "enabled": true,
      "port": 3003
    }
  },

  "memory": {
    "profile": "markdown_only",
    "backend": "markdown",
    "auto_save": true,
    "citations": "auto"
  },

  "gateway": {
    "port": 3004,
    "host": "127.0.0.1",
    "require_pairing": true
  },

  "security": {
    "sandbox": {
      "backend": "auto"
    },
    "audit": {
      "enabled": true
    }
  }
}
