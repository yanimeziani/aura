{
  "default_temperature": 0.3,

  "models": {
    "providers": {
      "openrouter": {
        "api_key": "YOUR_OPENROUTER_API_KEY"
      }
    }
  },

  "agents": {
    "devsecops": {
      "name": "DevSecOps Agent",
      "model": {
        "primary": "openrouter/meta-llama/llama-3.3-70b-instruct",
        "fallback": "openrouter/meta-llama/llama-3.3-70b-instruct"
      },
      "system_prompt_file": "prompts/devsecops_agent_prompt.txt",
      "max_tool_iterations": 25,
      "max_history": 50,
      "temperature": 0.3,
      "tools": [
        "web_fetch",
        "web_research"
      ],
      "memory": {
        "profile": "devsecops_ops",
        "auto_save": true,
        "context_window": 8000
      },
      "autonomy": {
        "level": "supervised",
        "workspace_only": true,
        "max_actions_per_hour": 40
      }
    },
    "defaults": {
      "model": {
        "primary": "openrouter/meta-llama/llama-3.3-70b-instruct"
      }
    }
  },

  "channels": {
    "cli": true,
    "web": {
      "enabled": true,
      "port": 3003
    }
  },

  "memory": {
    "profile": "markdown_only",
    "backend": "markdown",
    "auto_save": true,
    "citations": "auto",
    "lifecycle": {
      "hygiene_enabled": true,
      "archive_after_days": 14,
      "purge_after_days": 60,
      "conversation_retention_days": 60,
      "auto_hydrate": true
    }
  },

  "reliability": {
    "provider_retries": 3,
    "provider_backoff_ms": 800,
    "fallback_providers": [],
    "model_fallbacks": [
      "openrouter/meta-llama/llama-3.3-70b-instruct"
    ]
  },

  "autonomy": {
    "level": "supervised",
    "workspace_only": true,
    "max_actions_per_hour": 40
  },

  "gateway": {
    "port": 3000,
    "host": "127.0.0.1",
    "require_pairing": true
  },

  "security": {
    "sandbox": {
      "backend": "auto"
    },
    "audit": {
      "enabled": true
    }
  }
}
