{
  "default_temperature": 0.7,

  "models": {
    "providers": {
      "openrouter": {
        "api_key": "YOUR_OPENROUTER_API_KEY"
      }
    }
  },

  "agents": {
    "sdr": {
      "name": "SDR Agent",
      "model": {
        "primary": "openrouter/anthropic/claude-sonnet-4",
        "fallback": "openrouter/meta-llama/llama-3.3-70b-instruct"
      },
      "system_prompt_file": "prompts/sdr_agent_prompt.txt",
      "max_tool_iterations": 20,
      "max_history": 50,
      "temperature": 0.7,
      "tools": [
        "web_fetch",
        "web_research",
        "email_draft",
        "email_send",
        "calendar_link"
      ],
      "memory": {
        "profile": "sdr_campaigns",
        "auto_save": true,
        "context_window": 4000
      },
      "autonomy": {
        "level": "supervised",
        "workspace_only": true,
        "max_actions_per_hour": 20
      }
    },
    "defaults": {
      "model": {
        "primary": "openrouter/anthropic/claude-sonnet-4"
      }
    }
  },

  "channels": {
    "cli": true,
    "web": {
      "enabled": true,
      "port": 3002
    }
  },

  "memory": {
    "profile": "markdown_only",
    "backend": "markdown",
    "auto_save": true,
    "citations": "auto",
    "lifecycle": {
      "hygiene_enabled": true,
      "archive_after_days": 7,
      "purge_after_days": 30,
      "conversation_retention_days": 30,
      "auto_hydrate": true
    }
  },

  "reliability": {
    "provider_retries": 2,
    "provider_backoff_ms": 500,
    "fallback_providers": [],
    "model_fallbacks": [
      "openrouter/meta-llama/llama-3.3-70b-instruct",
      "openrouter/google/gemini-2.0-flash-exp:free"
    ]
  },

  "autonomy": {
    "level": "supervised",
    "workspace_only": true,
    "max_actions_per_hour": 20
  },

  "gateway": {
    "port": 3000,
    "host": "127.0.0.1",
    "require_pairing": true
  },

  "security": {
    "sandbox": {
      "backend": "auto"
    },
    "audit": {
      "enabled": true
    }
  }
}
