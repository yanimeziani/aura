#!/usr/bin/env bash
# openclaw — CLI control plane for OpenClaw orchestrator
# Works from: VPS (direct), Termux (via SSH), Debian host (via SSH)
# Usage: openclaw <command> [args]
#
# Commands:
#   status [--costs]           show agent status + optional cost breakdown
#   approve <task_id>          approve a HITL-gated task
#   reject  <task_id> [--reason "..."]
#   panic   on|off             activate / deactivate panic mode
#   agent   pause|resume <agent_id>
#   task    <type> [--file yaml_file]   submit a new task
#   logs    [agent_id] [--tail N]
#   costs   [--breakdown] [--period day|week]
#   queue   [--watch]          show HITL queue

set -euo pipefail

OPENCLAW_DIR="${OPENCLAW_DIR:-/data/openclaw}"
STATE_DIR="$OPENCLAW_DIR/state"
QUEUE_DIR="$OPENCLAW_DIR/hitl-queue"
ARTIFACTS_DIR="$OPENCLAW_DIR/artifacts"
LOG_DIR="$OPENCLAW_DIR/logs"
API_URL="${OPENCLAW_API_URL:-http://localhost:8080}"

# Colors
RED='\033[0;31m'; YELLOW='\033[0;33m'; GREEN='\033[0;32m'
BLUE='\033[0;34m'; BOLD='\033[1m'; RESET='\033[0m'

err()  { printf "${RED}[openclaw] error: %s${RESET}\n" "$*" >&2; exit 1; }
info() { printf "${BLUE}[openclaw]${RESET} %s\n" "$*"; }
ok()   { printf "${GREEN}[openclaw]${RESET} %s\n" "$*"; }
warn() { printf "${YELLOW}[openclaw]${RESET} %s\n" "$*"; }

need_dir() { mkdir -p "$STATE_DIR" "$QUEUE_DIR/pending" "$QUEUE_DIR/approved" "$QUEUE_DIR/rejected"; }

# ── api call helper ───────────────────────────────────────────────────────────
api() {
  local method="$1"; local path="$2"; shift 2
  curl -sf -X "$method" "$API_URL$path" \
    -H "Content-Type: application/json" \
    "$@" 2>/dev/null \
  || warn "Orchestrator API not reachable at $API_URL — using filesystem fallback"
}

# ── commands ──────────────────────────────────────────────────────────────────

cmd_status() {
  local COSTS=false
  [[ "${1:-}" == "--costs" ]] && COSTS=true

  printf "${BOLD}=== OpenClaw Status ===${RESET}\n\n"

  # Containers
  printf "${BOLD}Agents:${RESET}\n"
  for name in openclaw agent-devsecops agent-growth caddy vector; do
    local s
    s=$(docker inspect --format='{{.State.Status}}' "$name" 2>/dev/null || echo "not found")
    case "$s" in
      running)    printf "  ${GREEN}●${RESET} %-22s running\n" "$name:" ;;
      exited)     printf "  ${RED}✗${RESET} %-22s exited\n" "$name:" ;;
      *)          printf "  ${YELLOW}?${RESET} %-22s %s\n" "$name:" "$s" ;;
    esac
  done

  # HITL queue
  local PENDING
  PENDING=$(ls "$QUEUE_DIR/pending/"*.json 2>/dev/null | wc -l)
  printf "\n${BOLD}HITL queue:${RESET} "
  [[ "$PENDING" -gt 0 ]] \
    && printf "${YELLOW}%d pending${RESET}\n" "$PENDING" \
    || printf "${GREEN}clear${RESET}\n"

  # Panic mode
  printf "${BOLD}Panic mode:${RESET} "
  [[ -f "$STATE_DIR/panic_mode" ]] \
    && printf "${RED}ON${RESET}\n" \
    || printf "${GREEN}off${RESET}\n"

  if $COSTS; then
    cmd_costs
  fi
}

cmd_approve() {
  local TASK_ID="${1:-}"
  [[ -z "$TASK_ID" ]] && err "Usage: openclaw approve <task_id>"

  need_dir
  local FILE="$QUEUE_DIR/pending/task_${TASK_ID}.json"

  if [[ ! -f "$FILE" ]]; then
    err "Task not found in pending queue: $TASK_ID"
  fi

  # Try API first
  if api POST "/hitl/$TASK_ID/approve" > /dev/null 2>&1; then
    ok "Approved via API: $TASK_ID"
  else
    # Filesystem fallback
    mv "$FILE" "$QUEUE_DIR/approved/task_${TASK_ID}_$(date +%s).json"
    ok "Approved (filesystem): $TASK_ID"
  fi

  # Write audit log
  printf '{"task_id":"%s","action":"approved","by":"yani","ts":"%s"}\n' \
    "$TASK_ID" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    >> "$LOG_DIR/hitl-audit.log"
}

cmd_reject() {
  local TASK_ID="${1:-}"
  local REASON="no reason given"
  [[ -z "$TASK_ID" ]] && err "Usage: openclaw reject <task_id> [--reason '...']"
  if [[ "${2:-}" == "--reason" ]]; then REASON="${3:-}"; fi

  need_dir
  local FILE="$QUEUE_DIR/pending/task_${TASK_ID}.json"
  [[ ! -f "$FILE" ]] && err "Task not found: $TASK_ID"

  if api POST "/hitl/$TASK_ID/reject" -d "{\"reason\":\"$REASON\"}" > /dev/null 2>&1; then
    warn "Rejected via API: $TASK_ID (reason: $REASON)"
  else
    mv "$FILE" "$QUEUE_DIR/rejected/task_${TASK_ID}_$(date +%s).json"
    warn "Rejected (filesystem): $TASK_ID"
  fi

  printf '{"task_id":"%s","action":"rejected","reason":"%s","by":"yani","ts":"%s"}\n' \
    "$TASK_ID" "$REASON" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    >> "$LOG_DIR/hitl-audit.log"
}

cmd_panic() {
  local MODE="${1:-}"
  [[ "$MODE" != "on" && "$MODE" != "off" ]] && err "Usage: openclaw panic on|off"
  need_dir

  if [[ "$MODE" == "on" ]]; then
    touch "$STATE_DIR/panic_mode"
    # Pause growth agent container
    docker pause agent-growth 2>/dev/null \
      && warn "agent-growth paused" || warn "agent-growth pause failed (may already be stopped)"
    printf '{"event":"panic_mode_on","ts":"%s"}\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
      >> "$LOG_DIR/openclaw-system-system.log"
    warn "PANIC MODE ACTIVATED — growth agent paused, DevSecOps cheap-only"
  else
    rm -f "$STATE_DIR/panic_mode"
    docker unpause agent-growth 2>/dev/null \
      && ok "agent-growth resumed" || true
    printf '{"event":"panic_mode_off","ts":"%s"}\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
      >> "$LOG_DIR/openclaw-system-system.log"
    ok "Panic mode deactivated"
  fi
}

cmd_agent() {
  local ACTION="${1:-}"; local AGENT_ID="${2:-}"
  [[ -z "$ACTION" || -z "$AGENT_ID" ]] && err "Usage: openclaw agent pause|resume <agent_id>"

  local CONTAINER="agent-${AGENT_ID}"
  case "$ACTION" in
    pause)
      docker pause "$CONTAINER" 2>/dev/null && warn "Paused: $CONTAINER" \
        || err "Failed to pause $CONTAINER"
      printf '{"event":"agent_paused","agent":"%s","ts":"%s"}\n' \
        "$AGENT_ID" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$LOG_DIR/openclaw-system-system.log"
      ;;
    resume)
      docker unpause "$CONTAINER" 2>/dev/null && ok "Resumed: $CONTAINER" \
        || err "Failed to resume $CONTAINER"
      printf '{"event":"agent_resumed","agent":"%s","ts":"%s"}\n' \
        "$AGENT_ID" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$LOG_DIR/openclaw-system-system.log"
      ;;
    *)
      err "Unknown action: $ACTION (use pause|resume)"
      ;;
  esac
}

cmd_logs() {
  local AGENT_ID="${1:-system}"
  local TAIL="${3:-50}"
  [[ "${2:-}" == "--tail" ]] && TAIL="${3:-50}"

  local PATTERN="$LOG_DIR/openclaw-*${AGENT_ID}*.log"
  local FILES
  FILES=$(ls $PATTERN 2>/dev/null) || err "No logs found for agent: $AGENT_ID"

  tail -n "$TAIL" $FILES | python3 -c "
import json, sys
for line in sys.stdin:
    line = line.strip()
    if not line: continue
    try:
        d = json.loads(line)
        lvl  = d.get('level', 'info').upper()
        ts   = d.get('timestamp', '')[:19]
        msg  = d.get('message', line)[:100]
        comp = d.get('component', '')
        print(f'[{ts}] {lvl:<8} {comp:<15} {msg}')
    except:
        print(line)
" 2>/dev/null || tail -n "$TAIL" $FILES
}

cmd_costs() {
  local BREAKDOWN=false; local PERIOD="day"
  for arg in "$@"; do
    [[ "$arg" == "--breakdown" ]] && BREAKDOWN=true
    [[ "$arg" == "--period" ]]    && PERIOD="${2:-day}"
  done

  printf "\n${BOLD}=== Cost Report (${PERIOD}) ===${RESET}\n"

  local DATE
  DATE=$(date +%Y-%m-%d)
  local COST_FILE="$ARTIFACTS_DIR/devsecops/cost_report_${DATE}.md"

  if [[ -f "$COST_FILE" ]]; then
    grep -E "^[-*]|^##|Spend|Global|DevSecOps|Growth|Panic|Model" "$COST_FILE" | head -30
  else
    warn "No cost report for today yet. DevSecOps agent generates one daily."
    printf "  Tip: openclaw task cost_audit --file /dev/stdin <<< 'task_type: cost_audit\\nperiod: daily'\n"
  fi
}

cmd_queue() {
  local WATCH=false
  [[ "${1:-}" == "--watch" ]] && WATCH=true

  show_queue() {
    printf "${BOLD}=== HITL Queue ===${RESET}\n\n"
    local FILES
    FILES=$(ls "$QUEUE_DIR/pending/"*.json 2>/dev/null) || true
    if [[ -z "$FILES" ]]; then
      printf "${GREEN}No pending approvals.${RESET}\n"
      return
    fi
    local i=1
    while IFS= read -r f; do
      python3 -c "
import json
d = json.load(open('$f'))
print(f'  [{$i}] task: {d.get(\"task_id\",\"?\"):<20}  agent: {d.get(\"agent\",\"?\"):<12}')
print(f'       action: {d.get(\"action\",\"?\")}')
print(f'       risk:   {d.get(\"blast_radius\",\"?\")}  reversible: {d.get(\"reversible\",\"?\")}')
print()
" 2>/dev/null || printf "  [$i] %s\n" "$(basename "$f")"
      ((i++)) || true
    done <<< "$FILES"
    printf "  approve: openclaw approve <task_id>\n"
    printf "  reject:  openclaw reject <task_id> --reason '...'\n"
  }

  if $WATCH; then
    while true; do clear; show_queue; sleep 15; done
  else
    show_queue
  fi
}

cmd_task() {
  local TYPE="${1:-}"
  [[ -z "$TYPE" ]] && err "Usage: openclaw task <type> [--file yaml_file]"
  local YAML_FILE=""
  [[ "${2:-}" == "--file" ]] && YAML_FILE="${3:-}"

  local TASK_ID
  TASK_ID="${TYPE}-$(date +%s)"
  local PAYLOAD="{\"task_type\":\"$TYPE\",\"task_id\":\"$TASK_ID\",\"ts\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"}"

  if [[ -n "$YAML_FILE" && -f "$YAML_FILE" ]]; then
    # Convert YAML to JSON via python3
    PAYLOAD=$(python3 -c "
import yaml, json, sys
with open('$YAML_FILE') as f:
    d = yaml.safe_load(f)
d['task_id'] = '$TASK_ID'
d['ts'] = '$(date -u +%Y-%m-%dT%H:%M:%SZ)'
print(json.dumps(d))
" 2>/dev/null) || warn "YAML parse failed, sending minimal payload"
  fi

  if api POST "/tasks" -d "$PAYLOAD" > /dev/null 2>&1; then
    ok "Task submitted via API: $TASK_ID"
  else
    # Queue on filesystem for orchestrator to pick up
    need_dir
    printf '%s\n' "$PAYLOAD" > "$OPENCLAW_DIR/task-inbox/task_${TASK_ID}.json"
    mkdir -p "$OPENCLAW_DIR/task-inbox"
    printf '%s\n' "$PAYLOAD" > "$OPENCLAW_DIR/task-inbox/task_${TASK_ID}.json"
    ok "Task queued (filesystem): $TASK_ID"
  fi
}

cmd_help() {
  cat <<'EOF'
openclaw — OpenClaw control plane CLI

Commands:
  status [--costs]                    Agent status + optional cost summary
  approve <task_id>                   Approve a HITL-gated task
  reject  <task_id> [--reason '...'] Reject a HITL-gated task
  panic   on|off                      Activate / deactivate panic mode
  agent   pause|resume <id>           Pause or resume an agent (devsecops|growth)
  task    <type> [--file <yaml>]      Submit a task to the orchestrator
  logs    [agent_id] [--tail N]       Tail agent logs (default: last 50 lines)
  costs   [--breakdown] [--period]    Show cost report
  queue   [--watch]                   Show HITL approval queue

Examples:
  openclaw status --costs
  openclaw approve deploy-abc123
  openclaw reject scraper-xyz --reason "ToS unclear, needs review"
  openclaw panic on
  openclaw agent pause growth
  openclaw task deploy --file /tmp/deploy.yaml
  openclaw logs devsecops --tail 100
  openclaw queue --watch
EOF
}

# ── dispatch ──────────────────────────────────────────────────────────────────

COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
  status)  cmd_status  "$@" ;;
  approve) cmd_approve "$@" ;;
  reject)  cmd_reject  "$@" ;;
  panic)   cmd_panic   "$@" ;;
  agent)   cmd_agent   "$@" ;;
  logs)    cmd_logs    "$@" ;;
  costs)   cmd_costs   "$@" ;;
  queue)   cmd_queue   "$@" ;;
  task)    cmd_task    "$@" ;;
  help|-h|--help) cmd_help ;;
  *) err "Unknown command: $COMMAND. Run: openclaw help" ;;
esac
