# .env.example — OpenClaw Docker environment
# Copy to .env and fill in real values. NEVER commit .env.
# All secrets must come from env vars — never hardcode in code or prompts.

# ── Anthropic API ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# ── Alert channel ──────────────────────────────────────────────────────────
# Telegram bot: https://t.me/BotFather → create bot → get token + chat_id
# Discord webhook: Server Settings → Integrations → Webhooks
ALERT_WEBHOOK_URL=https://api.telegram.org/bot<TOKEN>/sendMessage?chat_id=<CHAT_ID>

# ── Cost caps (USD) ────────────────────────────────────────────────────────
DAILY_SPEND_CAP_USD=5.00

# ── Domain ─────────────────────────────────────────────────────────────────
DOMAIN=dragun.app

# ── Git credentials for agent branches ────────────────────────────────────
# Use a dedicated deploy key with write access to agent/* branches only
GIT_AUTHOR_NAME=openclaw-agent
GIT_AUTHOR_EMAIL=agent@dragun.app
GITHUB_TOKEN=ghp_...your-token-here...

# ── OpenClaw Auth (Pegasus login) ─────────────────────────────────────────
# Default admin user — CHANGE THIS after first login via Pegasus
OPENCLAW_ADMIN_PASSWORD=openclaw2026

# ── Dragun app database (if applicable) ────────────────────────────────────
# DATABASE_URL=postgres://user:password@host:5432/dragun

# ── Optional: Telegram bot token for HITL notifications ───────────────────
# TELEGRAM_BOT_TOKEN=<token>
# TELEGRAM_CHAT_ID=<chat_id>
