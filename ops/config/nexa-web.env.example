# Nexa web interface production environment
# Copy to /opt/nexa/runtime/apps/web/shared/.env.production on the VPS.

NODE_ENV=production
PORT=3003
HOSTNAME=127.0.0.1

NEXT_PUBLIC_URL=https://dragun.app
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

AI_PROVIDER=local
# LOCAL_API_BASE_URL=http://127.0.0.1:11434/v1
# LOCAL_MODEL=llama3.2
# LOCAL_API_KEY=ollama
# LOCAL_EMBEDDING_MODEL=nomic-embed-text
# LOCAL_FALLBACK_MODELS=llama3.2:3b
# GROQ_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-...

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...

SENTRY_DSN=https://...@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=

ARCJET_KEY=aj_...
DEBTOR_PORTAL_SECRET=replace-with-32-plus-char-secret
CRON_SECRET=replace-with-32-plus-char-secret

