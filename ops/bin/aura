#!/usr/bin/env bash
set -euo pipefail

resolve_realpath() {
    python3 - "$1" <<'PY'
import os
import sys
print(os.path.realpath(sys.argv[1]))
PY
}

resolve_runtime_path() {
    local kind="$1"
    PYTHONPATH="$AURA_ROOT${PYTHONPATH:+:$PYTHONPATH}" python3 - "$kind" <<'PY'
import sys
from aura_runtime import log_dir, vault_file

kind = sys.argv[1]
if kind == "vault_file":
    print(vault_file())
elif kind == "log_dir":
    print(log_dir())
else:
    raise SystemExit(f"Unknown runtime path kind: {kind}")
PY
}

# Resolve Aura repo root dynamically (override with AURA_ROOT if needed).
REAL_SCRIPT="$(resolve_realpath "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$REAL_SCRIPT")" && pwd)"
AURA_ROOT="${AURA_ROOT:-$(cd "$SCRIPT_DIR/../.." && pwd)}"
AURA_VAULT_FILE="${AURA_VAULT_FILE:-$(resolve_runtime_path vault_file)}"
AURA_LOG_DIR="${AURA_LOG_DIR:-$(resolve_runtime_path log_dir)}"
AURA_REMOTE_ROOT="${AURA_REMOTE_ROOT:-/opt/aura}"

function gateway_url() {
    echo "${AURA_GATEWAY_URL:-http://127.0.0.1:${AURA_GATEWAY_PORT:-8765}}"
}

function gateway_is_running() {
    local url="$1"
    python3 - "$url" <<'PY'
import json
import sys
import urllib.error
import urllib.request

url = sys.argv[1].rstrip("/") + "/health"
try:
    with urllib.request.urlopen(url, timeout=1.5) as response:
        payload = json.loads(response.read().decode())
    raise SystemExit(0 if payload.get("status") == "ok" else 1)
except Exception:
    raise SystemExit(1)
PY
}

function gateway_is_local() {
    local url="$1"
    python3 - "$url" <<'PY'
import sys
from urllib.parse import urlparse

host = (urlparse(sys.argv[1]).hostname or "").lower()
raise SystemExit(0 if host in {"", "127.0.0.1", "localhost", "0.0.0.0"} else 1)
PY
}

function start_gateway_background() {
    local port="${AURA_GATEWAY_PORT:-8765}"
    local log_dir="$AURA_LOG_DIR"
    mkdir -p "$log_dir"
    (cd "$AURA_ROOT/ops" && nohup env AURA_ROOT="$AURA_ROOT" AURA_VAULT_FILE="$AURA_VAULT_FILE" AURA_LOG_DIR="$AURA_LOG_DIR" \
        python3 -m uvicorn gateway.app:app --host 0.0.0.0 --port "$port" \
        >"$log_dir/gateway.log" 2>&1 < /dev/null &)
}

function show_help() {
    echo "Nexa CLI"
    echo "Usage: nexa <command> [options]"
    echo ""
    echo "Primary automation:"
    echo "  deploy-mesh   Deploy gateway + web services to VPS (backup first, then sync)"
    echo "  backup        Backup dynamic logs/json/md locally (or on VPS if AURA_REMOTE=1)"
    echo "  docs-bundle   Build NotebookLM-safe doc bundle (core docs + docs/updates/)"
    echo "  publish-notebooklm  Build + manifest + publish NotebookLM source bundle"
    echo "  notebooklm-upload   Optional Playwright upload into NotebookLM UI"
    echo "  smoke-test    Run smoke tests against deployed mesh services"
    echo "  demo          Start gateway + local UI for development"
    echo ""
    echo "Commands:"
    echo "  status      Check system health and agent states"
    echo "  start       Start core Nexa daemons (Autopilot, Web, API)"
    echo "  stop        Stop core Nexa daemons"
    echo "  vault       Manage API keys and secrets"
    echo "  logs        Tail the live agent metrics log"
    echo "  tui         Launch the Zig-based Terminal User Interface"
    echo "  mesh        Mesh VPN (Tailscale-like, Zig); up / down / status"
    echo "  lynx        Zig text browser (aura-lynx <url>)"
    echo "  api         Run aura-api (VPS HTTP server; AURA_API_PORT=9000)"
    echo "  gateway     Start syncing gateway (IDEs, TUIs, LLM clients through Nexa)"
    echo "  chat        Minimal TUI chat with Nexa agent (requires gateway; agent starts gateway if needed)"
    echo "  voice       Local 24/7 Fedora voice ingress (listen / start / stop / status / logs / transcribe)"
    echo "  opensea     OpenSea ops (read-only): assets / collections / watch"
    echo "  skill       Nexa skills belt (list/show/run)"
    echo "  docs-maid   Docs maid: persistent sweep of vault/docs_inbox → docs/, channel, vault"
    echo "  gs [N]      G100 benchmark: full workspace build + test; N epochs (default 1)"
    echo "  stub        Run a command under persistent stub (respawn on exit/kill)"
    echo "  stub-duplicate  Run a command under stub duplication (inner + outer respawn)"
    echo "  cd          Print Nexa repo root (use shell integration to cd)"
    echo "  help        Show this help message"
}

CMD="${1:-}"
case "$CMD" in
    ""|help|-h|--help)
        show_help
        ;;
    deploy-mesh)
        echo "Deploy mesh services to VPS..."
        REPO_ROOT="$AURA_ROOT" bash "$AURA_ROOT/ops/scripts/deploy-mesh.sh"
        ;;
    backup)
        echo "💾 Backup dynamic files (logs, json, md)..."
        if [[ -n "${AURA_REMOTE:-}" ]] && [[ "$AURA_REMOTE" != "0" ]]; then
            if [[ -z "${VPS_IP:-}" ]]; then
                echo "Set VPS_IP before running remote backup." >&2
                exit 1
            fi
            ssh "${VPS_USER:-root}@${VPS_IP}" "AURA_ROOT='${AURA_REMOTE_ROOT}' bash '${AURA_REMOTE_ROOT}/scripts/backup-dynamic-then-delete.sh' ${2:-}"
        else
            AURA_ROOT="$AURA_ROOT" bash "$AURA_ROOT/ops/scripts/backup-dynamic-then-delete.sh" "${@:2}"
        fi
        ;;
    docs-bundle)
        echo "📄 Building docs bundle (NotebookLM / public)..."
        REPO_ROOT="$AURA_ROOT" python3 "$AURA_ROOT/ops/scripts/build-aura-docs-bundle.py"
        ;;
    publish-notebooklm)
        echo "📦 Publishing NotebookLM bundle..."
        REPO_ROOT="$AURA_ROOT" AURA_ROOT="$AURA_ROOT" bash "$AURA_ROOT/ops/scripts/publish-notebooklm-bundle.sh"
        ;;
    notebooklm-upload)
        echo "🌐 Uploading into NotebookLM via Playwright..."
        cd "$AURA_ROOT" && node "$AURA_ROOT/ops/scripts/notebooklm-upload.mjs"
        ;;
    smoke-test)
        echo "Run mesh smoke tests..."
        if [[ -z "${VPS_IP:-}" ]]; then
            echo "Set VPS_IP before running smoke-test." >&2
            exit 1
        fi
        if [[ -n "${MESH_LANDING_URL:-}" ]]; then
            REPO_ROOT="$AURA_ROOT" MESH_VPS_IP="${VPS_IP}" MESH_LANDING_URL="${MESH_LANDING_URL}" bash "$AURA_ROOT/ops/scripts/smoke-test-mesh.sh"
        else
            REPO_ROOT="$AURA_ROOT" MESH_VPS_IP="${VPS_IP}" bash "$AURA_ROOT/ops/scripts/smoke-test-mesh.sh"
        fi
        ;;
    demo)
        echo "Starting local gateway and UI..."
        export AURA_ROOT="$AURA_ROOT" AURA_VAULT_FILE="$AURA_VAULT_FILE" AURA_LOG_DIR="$AURA_LOG_DIR"
        if ! gateway_is_running "$(gateway_url)"; then
            echo "  Starting gateway in background..."
            start_gateway_background
            for _ in {1..20}; do
                gateway_is_running "$(gateway_url)" && break
                sleep 0.5
            done
        fi
        echo "  Gateway: $(gateway_url)"
        echo "  Starting local UI..."
        (cd "$AURA_ROOT/apps/aura-dashboard" && AURA_DASHBOARD_PORT="${AURA_DASHBOARD_PORT:-3003}" npm run dev 2>/dev/null &) || true
        echo "  Ready. Open http://localhost:${AURA_DASHBOARD_PORT:-3003} and use the vault token to log in."
        echo "  Docs URL: $(gateway_url)/docs/nexa"
        ;;
    status)
        echo "📊 Nexa System Status:"
        if command -v systemctl >/dev/null 2>&1 && systemctl is-system-running >/dev/null 2>&1; then
            sudo systemctl is-active aura_autopilot.service ai_pay.service ai_agency_web.service || true
        else
            echo "Systemd not detected or inactive. Checking processes via ps:"
            ps aux | grep -E "aura-stub|autopilot.sh|run_server.sh|next dev" | grep -v grep || echo "No active Aura processes found."
        fi
        echo ""
        echo "Health Report:"
        if [ -f "$AURA_ROOT/apps/wealth/watchdog_state.json" ]; then
            cat "$AURA_ROOT/apps/wealth/watchdog_state.json"
        elif [ -f "$AURA_ROOT/ai_agency_wealth/watchdog_state.json" ]; then
             cat "$AURA_ROOT/ai_agency_wealth/watchdog_state.json"
        else
            echo "No health data yet."
        fi
        ;;
    start)
        echo "🚀 Starting Aura Systems..."
        if command -v systemctl >/dev/null 2>&1 && systemctl is-system-running >/dev/null 2>&1; then
            sudo systemctl start aura_autopilot.service ai_pay.service ai_agency_web.service
            echo "✅ Services started via systemctl."
        else
             echo "Systemd is not available to start services as daemons."
             echo "Run the services manually if needed:"
             echo " - Autopilot: cd $AURA_ROOT/apps/wealth && ./autopilot.sh"
             echo " - AI Pay: cd $AURA_ROOT/apps/wealth && ./run_server.sh"
             echo " - AI Web: cd $AURA_ROOT/apps/web && npm run dev"
        fi
        ;;
    stop)
        echo "🛑 Stopping Aura Systems..."
        if command -v systemctl >/dev/null 2>&1 && systemctl is-system-running >/dev/null 2>&1; then
            sudo systemctl stop aura_autopilot.service ai_pay.service ai_agency_web.service
            echo "✅ Services stopped via systemctl."
        else
             echo "Systemd is not available. Please stop manual processes via kill/Ctrl-C."
        fi
        ;;
    vault)
        python3 "$AURA_ROOT/vault/vault_manager.py"
        ;;
    logs)
        if [ -f "$AURA_ROOT/apps/wealth/agency_metrics.log" ]; then
            tail -f "$AURA_ROOT/apps/wealth/agency_metrics.log"
        elif [ -f "$AURA_ROOT/ai_agency_wealth/agency_metrics.log" ]; then
            tail -f "$AURA_ROOT/ai_agency_wealth/agency_metrics.log"
        else
            echo "No agent metrics log found yet."
        fi
        ;;
    tui)
        if [ -x "$AURA_ROOT/core/tui/zig-out/bin/aura-tui" ]; then
            "$AURA_ROOT/core/tui/zig-out/bin/aura-tui"
        else
            echo "⚙️ Building TUI for the first time..."
            cd "$AURA_ROOT/core/tui" && zig build
            "$AURA_ROOT/core/tui/zig-out/bin/aura-tui"
        fi
        ;;
    mesh)
        if [ -x "$AURA_ROOT/core/aura-tailscale/zig-out/bin/aura-mesh" ]; then
            "$AURA_ROOT/core/aura-tailscale/zig-out/bin/aura-mesh" "${@:2}"
        else
            echo "⚙️ Building Aura mesh (aura-tailscale) for the first time..."
            cd "$AURA_ROOT/core/aura-tailscale" && zig build
            "$AURA_ROOT/core/aura-tailscale/zig-out/bin/aura-mesh" "${@:2}"
        fi
        ;;
    lynx)
        if [ -x "$AURA_ROOT/core/aura-lynx/zig-out/bin/aura-lynx" ]; then
            "$AURA_ROOT/core/aura-lynx/zig-out/bin/aura-lynx" "${@:2}"
        else
            echo "⚙️ Building aura-lynx for the first time..."
            cd "$AURA_ROOT/core/aura-lynx" && zig build
            "$AURA_ROOT/core/aura-lynx/zig-out/bin/aura-lynx" "${@:2}"
        fi
        ;;
    api)
        if [ -x "$AURA_ROOT/core/aura-api/zig-out/bin/aura-api" ]; then
            "$AURA_ROOT/core/aura-api/zig-out/bin/aura-api" "${@:2}"
        else
            echo "⚙️ Building aura-api for the first time..."
            cd "$AURA_ROOT/core/aura-api" && zig build
            "$AURA_ROOT/core/aura-api/zig-out/bin/aura-api" "${@:2}"
        fi
        ;;
    gateway)
        export AURA_ROOT="$AURA_ROOT" AURA_VAULT_FILE="$AURA_VAULT_FILE" AURA_LOG_DIR="$AURA_LOG_DIR"
        cd "$AURA_ROOT/ops" && python3 -m uvicorn gateway.app:app --host 0.0.0.0 --port "${AURA_GATEWAY_PORT:-8765}"
        ;;
    chat)
        # Minimal TUI chat with agent; start local gateway if needed.
        export AURA_ROOT="$AURA_ROOT" AURA_VAULT_FILE="$AURA_VAULT_FILE" AURA_LOG_DIR="$AURA_LOG_DIR"
        CHAT_GATEWAY_URL="$(gateway_url)"
        export AURA_GATEWAY_URL="$CHAT_GATEWAY_URL"
        if ! gateway_is_running "$CHAT_GATEWAY_URL"; then
            if gateway_is_local "$CHAT_GATEWAY_URL"; then
                echo "⚙️ Starting Aura gateway in background..."
                start_gateway_background
                for _ in {1..20}; do
                    if gateway_is_running "$CHAT_GATEWAY_URL"; then
                        break
                    fi
                    sleep 0.5
                done
            fi
        fi
        exec python3 "$AURA_ROOT/ops/gateway/aura_tui_chat.py"
        ;;
    voice)
        shift
        VOICE_CMD="${1:-help}"
        USER_SYSTEMD_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
        REPO_VOICE_SERVICE="$AURA_ROOT/ops/config/aura_voice.service"
        USER_VOICE_SERVICE="$USER_SYSTEMD_DIR/aura_voice.service"

        ensure_voice_service() {
            mkdir -p "$USER_SYSTEMD_DIR"
            install -m 0644 "$REPO_VOICE_SERVICE" "$USER_VOICE_SERVICE"
            systemctl --user daemon-reload
        }

        case "$VOICE_CMD" in
            transcribe)
                shift
                exec python3 "$AURA_ROOT/vault/voice_ingress.py" transcribe "$@"
                ;;
            listen)
                shift
                exec python3 "$AURA_ROOT/vault/voice_ingress.py" listen "$@"
                ;;
            show)
                shift
                exec python3 "$AURA_ROOT/vault/voice_ingress.py" show "$@"
                ;;
            start)
                if command -v systemctl >/dev/null 2>&1 && systemctl --user is-system-running >/dev/null 2>&1; then
                    ensure_voice_service
                    exec systemctl --user enable --now aura_voice.service
                else
                    echo "User-level Systemd not available. Starting voice ingress manually in background..."
                    mkdir -p "$AURA_ROOT/.aura/logs"
                    nohup python3 "$AURA_ROOT/vault/voice_ingress.py" listen > "$AURA_ROOT/.aura/logs/voice.log" 2>&1 &
                    echo "✅ Voice ingress started in background (PID $!)."
                fi
                ;;
            stop)
                if command -v systemctl >/dev/null 2>&1 && systemctl --user is-system-running >/dev/null 2>&1; then
                    exec systemctl --user stop aura_voice.service
                else
                    echo "Stopping voice ingress process..."
                    pkill -f "voice_ingress.py" || echo "No voice ingress process found."
                fi
                ;;
            restart)
                if command -v systemctl >/dev/null 2>&1 && systemctl --user is-system-running >/dev/null 2>&1; then
                    ensure_voice_service
                    exec systemctl --user restart aura_voice.service
                else
                    $0 voice stop
                    $0 voice start
                fi
                ;;
            status)
                if command -v systemctl >/dev/null 2>&1 && systemctl --user is-system-running >/dev/null 2>&1; then
                    exec systemctl --user status aura_voice.service --no-pager
                else
                    echo "User-level Systemd not available. Checking for voice ingress process:"
                    ps aux | grep "voice_ingress.py" | grep -v grep || echo "Aura voice service is not running."
                fi
                ;;
            logs)
                if command -v journalctl >/dev/null 2>&1 && systemctl --user is-system-running >/dev/null 2>&1; then
                    exec journalctl --user -u aura_voice.service -f
                else
                    tail -f "$AURA_ROOT/.aura/logs/voice.log"
                fi
                ;;
            help|-h|--help|"")
                echo "Aura voice commands:"
                echo "  aura voice transcribe <audio-file> [--json]"
                echo "  aura voice listen [--keep-audio]"
                echo "  aura voice show"
                echo "  aura voice start | stop | restart | status | logs"
                ;;
            *)
                echo "Unknown aura voice subcommand: $VOICE_CMD" >&2
                exit 1
                ;;
        esac
        ;;
    opensea)
        shift
        exec "$AURA_ROOT/ops/bin/aura-opensea" "$@"
        ;;
    skill)
        shift
        exec "$AURA_ROOT/ops/bin/aura-skill" "$@"
        ;;
    docs-maid)
        shift
        exec "$AURA_ROOT/ops/bin/docs-maid" "${@:-run}"
        ;;
    gs)
        exec "$AURA_ROOT/ops/bin/aura-gs" "${@:2}"
        ;;
    stub)
        shift
        exec "$AURA_ROOT/ops/bin/aura-stub" run -- "$@"
        ;;
    stub-duplicate)
        shift
        exec "$AURA_ROOT/ops/bin/aura-stub" duplicate -- "$@"
        ;;
    cd)
        echo "$AURA_ROOT"
        echo "Tip: in zsh, source '$AURA_ROOT/ops/bin/aura.zsh' to enable 'aura cd' to cd in-place."
        ;;
    *)
        show_help
        ;;
esac
