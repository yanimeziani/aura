#!/usr/bin/env bash
# Aura persistent stub: always-on supervisor with stub duplication for catch kill.
# - Inner stub (run): runs COMMAND in a loop; on exit or kill of child, respawns.
# - Outer stub (duplicate): runs the inner stub in a loop; if inner is killed, respawns inner.
# So: kill worker → inner respawns worker; kill inner → outer respawns inner; kill outer → systemd (or manual) restarts.
# Usage:
#   aura-stub run -- <command [args...]>
#   aura-stub duplicate -- <command [args...]>   # always-on with stub duplication

set -e
AURA_ROOT="${AURA_ROOT:-/home/yani/Aura}"
RESPAWN_DELAY="${AURA_STUB_RESPAWN_DELAY:-2}"

usage() {
    echo "Usage: aura-stub run -- <command [args...]>"
    echo "       aura-stub duplicate -- <command [args...]>"
    echo "  run       Inner stub: run command, respawn on exit/kill."
    echo "  duplicate Outer stub: run inner stub in a loop (respawn inner on kill)."
    exit 1
}

# Forward SIGTERM/SIGINT to child so child can shut down; we keep running and respawn after.
forward_signal() {
    if [[ -n "${CHILD_PID:-}" ]] && kill -0 "$CHILD_PID" 2>/dev/null; then
        kill -TERM "$CHILD_PID" 2>/dev/null || true
    fi
}

run_inner() {
    if [[ "$1" != "--" ]] || [[ $# -lt 2 ]]; then
        usage
    fi
    shift
    local cmd=("$@")
    trap 'forward_signal' TERM INT

    while true; do
        "${cmd[@]}" &
        CHILD_PID=$!
        set +e
        wait $CHILD_PID
        exitcode=$?
        set -e
        CHILD_PID=""
        echo "[aura-stub] $(date -Iseconds) child exited with $exitcode; respawning in ${RESPAWN_DELAY}s"
        sleep "$RESPAWN_DELAY"
    done
}

# Outer stub: run inner stub in a loop so that if inner is killed we respawn it.
run_duplicate() {
    if [[ "$1" != "--" ]] || [[ $# -lt 2 ]]; then
        usage
    fi
    shift
    local cmd=("$@")
    local inner=("$0" "run" "--" "${cmd[@]}")

    while true; do
        echo "[aura-stub duplicate] $(date -Iseconds) starting inner stub"
        "${inner[@]}" || true
        echo "[aura-stub duplicate] $(date -Iseconds) inner stub exited; respawning in ${RESPAWN_DELAY}s"
        sleep "$RESPAWN_DELAY"
    done
}

case "${1:-}" in
    run)     shift; run_inner "$@" ;;
    duplicate) shift; run_duplicate "$@" ;;
    *)       usage ;;
esac
