#!/usr/bin/env bash
# G-series runner: full workspace build + test (G100 Aura Benchmark).
# Usage: aura gs [epochs]
#   epochs = number of full build+test cycles (default 1). E.g. aura gs 100
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AURA_ROOT="${AURA_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
cd "$AURA_ROOT"

EPOCHS="${1:-1}"
if ! [[ "$EPOCHS" =~ ^[0-9]+$ ]] || [[ "$EPOCHS" -lt 1 ]]; then
  echo "Usage: aura gs [epochs]   # epochs = positive integer (default 1)"
  exit 1
fi

# Packages that expose zig build test (from build.zig.zon + build.zig inspection)
TEST_PACKAGES=(ziggy-compiler aura-api aura-mcp aura-tailscale aura-edge tui)

run_one_epoch() {
  local epoch="$1"
  echo ""
  echo "═══ Epoch $epoch/$EPOCHS ═══"
  # Full workspace build (installs all artifacts)
  zig build
  for pkg in "${TEST_PACKAGES[@]}"; do
    if [[ -d "$AURA_ROOT/$pkg" ]]; then
      (cd "$AURA_ROOT/$pkg" && zig build test) || return 1
    fi
  done
  echo "✅ Epoch $epoch done"
}

FAILED_EPOCH=""
for ((e=1; e<=EPOCHS; e++)); do
  if ! run_one_epoch "$e"; then
    FAILED_EPOCH="$e"
    break
  fi
done

if [[ -n "$FAILED_EPOCH" ]]; then
  echo ""
  echo "❌ G100 gs failed at epoch $FAILED_EPOCH"
  exit 1
fi

echo ""
echo "✅ G100 gs complete — $EPOCHS epoch(s) passed."
