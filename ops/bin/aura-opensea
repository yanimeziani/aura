#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AURA_ROOT="${AURA_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"

usage() {
  cat <<'EOF'
Usage:
  aura opensea                # internet check + open opensea.io (text)
  aura opensea status         # internet check only
  aura opensea open [url]     # open url in aura lynx (default: https://opensea.io)

Notes:
  - This is read-only and safe: no signing, no transactions, no keys.
EOF
}

internet_status() {
  echo "[opensea] checking internet..."

  if command -v getent >/dev/null 2>&1; then
    if getent ahosts example.com >/dev/null 2>&1; then
      echo "[opensea] DNS: ok"
    else
      echo "[opensea] DNS: failed"
      return 2
    fi
  else
    echo "[opensea] DNS: (skipped; getent not found)"
  fi

  if command -v curl >/dev/null 2>&1; then
    if curl -fsS --max-time 8 https://example.com >/dev/null; then
      echo "[opensea] HTTPS: ok"
    else
      if curl -fsS --insecure --max-time 8 https://example.com >/dev/null; then
        echo "[opensea] HTTPS: ok (insecure; missing system CA bundle)"
        return 0
      fi
      echo "[opensea] HTTPS: failed"
      return 3
    fi
  else
    echo "[opensea] HTTPS: (skipped; curl not found)"
  fi
}

open_url() {
  local url="${1:-https://opensea.io}"
  if [[ "$url" != http://* && "$url" != https://* ]]; then
    url="https://$url"
  fi

  if [[ -x "$AURA_ROOT/aura-lynx/zig-out/bin/aura-lynx" ]]; then
    exec "$AURA_ROOT/aura-lynx/zig-out/bin/aura-lynx" "$url"
  fi

  # Fallback to Aura CLI's `lynx` command (it will build on first run).
  if [[ -x "$AURA_ROOT/bin/aura" ]]; then
    exec "$AURA_ROOT/bin/aura" lynx "$url"
  fi

  echo "$url"
  echo "[opensea] couldn't find aura-lynx; open the URL above."
}

cmd="${1:-}"
case "$cmd" in
  "" )
    internet_status || true
    open_url "https://opensea.io"
    ;;
  help|-h|--help )
    usage
    ;;
  status )
    internet_status
    ;;
  open )
    shift
    internet_status || true
    open_url "${1:-https://opensea.io}"
    ;;
  * )
    echo "[opensea] unknown command: $cmd" >&2
    usage >&2
    exit 1
    ;;
esac
