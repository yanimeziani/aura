# Domain Caddy serves (required for deploy)
DOMAIN=

# Optional: deploy/stream from this machine to VPS via SSH (deploy-remote, stream-remote)
# Use the VPS Tailscale hostname so any device on your Tailscale network can run deploy-remote / stream-remote.
# Do not commit .env; copy to .env and set values. Private keys stay in ~/.ssh/.
# VPS_HOST=myvps.5tail12345.ts.net
# VPS_USER=yani
# VPS_REPO_PATH=/home/yani/aura-stack
# SSH_KEY_PATH=   # optional; default: ~/.ssh/id_ed25519 or ~/.ssh/id_rsa

# Optional: paths when running prod-control.sh locally
# FRONTEND_SRC=/path/to/ai_agency_web
# SOVEREIGN_STACK_DIR=/path/to/sovereign-stack
