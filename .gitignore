# --- Nexa Monorepo Ignore List ---

# Environment Secrets (CRITICAL)
.env
.env.*
!.env.example
*.env
*.key
*.pem
*.p12

# Node.js
node_modules/
dist/
build/
.next/
out/
.vercel
.npm
.turbo

# Zig (Cerberus + Nexa)
zig-cache/
zig-out/
.zig-cache/
/core/cerberus/zig-cache/
/core/cerberus/zig-out/

# Python cache
__pycache__/
*.pyc

# Vault secrets (NEVER commit)
vault/aura-vault.json
vault/nexa-vault.json

# Android/Kotlin (Pegasus)
.gradle/
/apps/mobile/build/
/apps/mobile/.gradle/
local.properties
*.apk
*.aar

# System & IDE
.DS_Store
.vscode/
.idea/
*.swp
*.log
.gemini/
.claude/
.cerberus/memory/
archive/

# Temporary
/root/.gemini/tmp/
tmp/
Downloads/
*.tar.gz
*.zip

# Ignore root hidden files and folders
/.*
!/.gitignore
!/.github/
!/.env.example

# specific folders to ignore
/android-sdk/
/exports/
/archive/
/Aura_Full_Documentation_Export.txt
/Aura_Full_Documentation_Export.md
/Nexa_Full_Documentation_Export.txt
/Nexa_Full_Documentation_Export.md
/aura_bundle.tar.gz
/exports/notebook-lm/Aura_*
/apps/web/public/Aura_Full_Documentation_Export.txt
/nexa-docs-notebooklm.txt
/deployment.log
/your
*.tsbuildinfo
